generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Candidate {
  id        String   @id @default(cuid())
  name      String
  race      String
  state     String
  party     String
  incumbent Boolean  @default(false)
  createdAt DateTime @default(now())
  bins      Bin[]
}

model Outlet {
  id       String    @id @default(cuid())
  name     String
  type     String    // News | Blog | Social | TV | Radio | Other
  reach    String?
  leaning  String?
  articles Article[]
}

model Article {
  id           String   @id @default(cuid())
  title        String
  url          String   @unique
  datePublished DateTime
  outletId     String
  outlet       Outlet   @relation(fields: [outletId], references: [id])
  author       String?
  language     String   @default("en")
  region       String?
  sourceType   String   // News | Blog | Social | PressRelease
  rawText      String
  summary      String?
  bucket       String?  // CandidateCoverage | OpponentCoverage | GeneralRace | HotButtons
  topics       String   @default("[]") // JSON array stored as string
  sentiment    String?  // Positive | Neutral | Negative
  confidence   Float?
  createdAt    DateTime @default(now())
  binItems     BinItem[]
}

model Bin {
  id          String    @id @default(cuid())
  candidateId String
  candidate   Candidate @relation(fields: [candidateId], references: [id])
  name        String
  dateCreated DateTime  @default(now())
  digest      String?
  items       BinItem[]
  briefs      Brief[]
  exports     Export[]
}

model BinItem {
  id        String  @id @default(cuid())
  binId     String
  bin       Bin     @relation(fields: [binId], references: [id])
  articleId String
  article   Article @relation(fields: [articleId], references: [id])
  sortOrder Int     @default(0)

  @@unique([binId, articleId])
}

model Brief {
  id         String   @id @default(cuid())
  binId      String
  bin        Bin      @relation(fields: [binId], references: [id])
  type       String   // DailyDigest | IssueBrief | NeedToKnow | Newsletter | Email | SocialCopy | EventRequest
  content    String
  templateId String?
  template   Template? @relation(fields: [templateId], references: [id])
  createdAt  DateTime @default(now())
}

model Template {
  id             String  @id @default(cuid())
  name           String
  type           String
  structure      String  // JSON: sections + placeholders
  defaultContent String
  briefs         Brief[]
}

model Export {
  id          String   @id @default(cuid())
  binId       String
  bin         Bin      @relation(fields: [binId], references: [id])
  format      String   // CSV | JSON | Markdown
  content     String
  generatedAt DateTime @default(now())
  status      String   @default("ready")
}

model MediaPack {
  id        String   @id @default(cuid())
  date      String   @unique
  content   String   // JSON
  createdAt DateTime @default(now())
}

model DailyBrief {
  id        String   @id @default(cuid())
  date      String   @unique // YYYY-MM-DD
  content   String
  createdAt DateTime @default(now())
}

model AuditLog {
  id        String   @id @default(cuid())
  action    String
  entity    String
  entityId  String
  userId    String?
  meta      String?
  createdAt DateTime @default(now())
}

model Contact {
  id          String   @id @default(cuid())
  createdAt   DateTime @default(now())
  candidateId String?
  name        String
  phone       String?
  email       String?
  address     String?
  method      String   @default("phone")     // door | phone | text | email
  status      String   @default("completed") // completed | attempted | pending
  contactedAt DateTime @default(now())
  notes       String?

  @@index([candidateId])
}

model Donor {
  id          String    @id @default(cuid())
  createdAt   DateTime  @default(now())
  candidateId String?
  name        String
  email       String?
  phone       String?
  amount      Float     @default(0)
  donatedAt   DateTime  @default(now())
  method      String?   // online | check | cash | card
  followUpDue DateTime?
  notes       String?
  status      String    @default("received") // received | follow_up_needed | thanked

  @@index([candidateId])
}

model Volunteer {
  id          String   @id @default(cuid())
  createdAt   DateTime @default(now())
  candidateId String?
  name        String
  email       String?
  phone       String?
  role        String?
  shiftDate   DateTime
  shiftStart  String?
  shiftEnd    String?
  status      String   @default("scheduled") // scheduled | confirmed | completed | no_show
  notes       String?

  @@index([candidateId])
}

model CampaignEvent {
  id          String   @id @default(cuid())
  createdAt   DateTime @default(now())
  candidateId String?
  title       String
  type        String   @default("event") // rally | townhall | fundraiser | canvass | debate | meeting
  eventDate   DateTime
  location    String?
  description String?
  status      String   @default("upcoming") // upcoming | completed | cancelled

  @@index([candidateId])
}

model ContentDraft {
  id          String   @id @default(cuid())
  createdAt   DateTime @default(now())
  candidateId String?
  title       String
  type        String   @default("social") // social | email | press_release | ad | mailer
  content     String
  platform    String?
  status      String   @default("pending") // pending | approved | rejected
  notes       String?

  @@index([candidateId])
}

model Voter {
  id              String    @id @default(cuid())
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  candidateId     String?
  firstName       String
  lastName        String
  address         String?
  city            String?
  zip             String?
  phone           String?
  email           String?
  party           String?   // Republican | Democrat | Independent | Unknown
  supportLevel    String?   // Strong Support | Lean Support | Persuadable | Opposed | Unknown
  turnoutScore    Float?
  precinct        String?
  tags            String    @default("[]") // JSON array
  notes           String?
  lastContactedAt DateTime?
  contactStatus   String    @default("Not Contacted") // Not Contacted | Reached | Left Message | Wrong Number | Do Not Contact | Needs Follow-Up

  @@index([candidateId])
  @@index([party])
  @@index([contactStatus])
}
